{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "fullName": { "type": "string" },
        "city": { "type": "string" },
        "photoURL": { "type": "string" },
        "traderTypes": { "type": "array", "items": { "type": "string" } },
        "marketPreferences": { "type": "array", "items": { "type": "string" } },
        "experienceLevel": { "type": "string", "enum": ["Beginner", "Intermediate", "Advanced"] },
        "goals": { "type": "array", "items": { "type": "string" } },
        "currency": { "type": "string" },
        "onboardingCompleted": { "type": "boolean" },
        "plan": { "type": "string", "enum": ["FREE", "PRO", "ELITE"] },
        "subscriptionStatus": { "type": "string", "enum": ["active", "expired", "canceled"] },
        "subscriptionExpiry": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "firstName", "lastName", "fullName", "onboardingCompleted", "plan", "subscriptionStatus", "createdAt"]
    },
    "Trade": {
      "title": "Trade",
      "description": "Trading journal entry",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "marketType": { "type": "string" },
        "symbol": { "type": "string" },
        "direction": { "type": "string", "enum": ["Long", "Short"] },
        "setupType": { "type": "string" },
        "entryPrice": { "type": "number" },
        "exitPrice": { "type": "number" },
        "stopLoss": { "type": "number" },
        "targetPrice": { "type": "number" },
        "quantity": { "type": "number" },
        "riskAmount": { "type": "number" },
        "rrRatio": { "type": "number" },
        "leverage": { "type": "number" },
        "margin": { "type": "number" },
        "fees": { "type": "number" },
        "currency": { "type": "string" },
        "notes": { "type": "string" },
        "emotionBefore": { "type": "string" },
        "emotionAfter": { "type": "string" },
        "confidence": { "type": "number" },
        "ruleFollowed": { "type": "boolean" },
        "screenshotURL": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "grossPL": { "type": "number" },
        "netPL": { "type": "number" },
        "roi": { "type": "number" },
        "status": { "type": "string", "enum": ["Win", "Loss", "Breakeven"] },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "symbol", "direction", "entryPrice", "exitPrice", "quantity", "netPL", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "Community post",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "content": { "type": "string" },
        "imageURL": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "userName", "content", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Comment on a post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["postId", "userId", "userName", "content", "createdAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "Direct message conversation",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastTimestamp": { "type": "number" },
        "unreadCount": { "type": "object" }
      },
      "required": ["participants", "lastTimestamp"]
    },
    "Message": {
      "title": "Message",
      "description": "Direct message",
      "type": "object",
      "properties": {
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "number" },
        "read": { "type": "boolean" }
      },
      "required": ["conversationId", "senderId", "receiverId", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Trading journal entries"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Community posts"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on community posts"
    },
    "/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Direct message conversations"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Direct messages"
    }
  }
}
