rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin') ||
         (request.auth.token.email == "ashwanikumar56647@gmail.com" && request.auth.token.get('email_verified', false) == true));
    }

    function isValidUser(data) {
      // Basic type validation for what's present
      return (data.get('uid', request.auth.uid) == request.auth.uid) &&
             (!('email' in data) || (data.email is string)) &&
             (!('fullName' in data) || (data.fullName is string && data.fullName.size() < 100)) &&
             (!('onboardingCompleted' in data) || data.onboardingCompleted is bool) &&
             (!('createdAt' in data) || data.createdAt is number) &&
             (!('plan' in data) || data.plan in ['FREE', 'PRO', 'ELITE']) &&
             (!('subscriptionStatus' in data) || data.subscriptionStatus in ['active', 'expired', 'canceled']) &&
             (!('traderTypes' in data) || data.traderTypes is list) &&
             (!('marketPreferences' in data) || data.marketPreferences is list) &&
             (!('experienceLevel' in data) || data.experienceLevel is string) &&
             (!('goals' in data) || data.goals is list) &&
             (!('currency' in data) || data.currency is string) &&
             (!('photoURL' in data) || data.photoURL == null || data.photoURL is string);
    }

    function isValidTrade(data) {
      return data.keys().hasAll(['userId', 'symbol', 'direction', 'entryPrice', 'exitPrice', 'quantity', 'netPL', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.symbol is string && data.symbol.size() > 0 && data.symbol.size() < 50 &&
             data.direction in ['Long', 'Short'] &&
             data.entryPrice is number &&
             data.exitPrice is number &&
             data.quantity is number &&
             data.netPL is number &&
             data.createdAt is number;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['userId', 'userName', 'content', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.userName is string &&
             data.createdAt is number;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['postId', 'userId', 'userName', 'content', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.content is string && data.content.size() > 0 && data.content.size() < 1000 &&
             data.userName is string &&
             data.createdAt is number;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /trades/{tradeId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidTrade(request.resource.data);
      allow update: if (isDocOwner() && isValidTrade(request.resource.data)) || isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if (isDocOwner() && isValidPost(request.resource.data)) || isAdmin();
      allow delete: if isDocOwner() || isAdmin();

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidComment(request.resource.data);
        allow update: if (isDocOwner() && isValidComment(request.resource.data)) || isAdmin();
        allow delete: if isDocOwner() || isAdmin();
      }
    }

    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.receiverId; // For marking as read
      allow delete: if isAdmin();
    }
  }
}
